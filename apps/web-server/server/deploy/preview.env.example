# preview.env — host configuration for preview-runner.sh
# Copy to /etc/magestic-preview/preview.env (root:root, chmod 600) on the deploy host.
# Secrets live here, NOT in the deploy.config.json and NOT passed as CLI args.

# --- Postgres (for clone-from-golden + drop) ---
# The runner uses standard PG* vars. The role must own/clone the golden DBs.
PGHOST=127.0.0.1
PGPORT=5435
PGUSER=cts
PGPASSWORD=change-me
# DB used for admin connections (CREATE/DROP DATABASE). Default: postgres
PGADMIN_DB=postgres
# Hostname containers use to reach Postgres (if different from PGHOST, e.g. the
# docker bridge gateway 172.17.0.1 or a service name). Defaults to PGHOST.
PREVIEW_DB_HOST_FOR_CONTAINERS=172.17.0.1

# --- Golden seed DBs (the 2 static "starting" databases) ---
PREVIEW_GOLDEN_DB_A=cts_golden_a   # lane A = main / pre-prod
PREVIEW_GOLDEN_DB_B=cts_golden_b   # lane B = test
# Persistent DBs the static lanes run against (default to the golden DBs).
PREVIEW_STATIC_DB_A=cts_static_a
PREVIEW_STATIC_DB_B=cts_static_b

# --- Networking / exposure ---
# Distinct LAN IP / hostname previews are reachable on. Defaults to first host IP.
PREVIEW_PUBLIC_HOST=192.168.88.55
PREVIEW_PORT_MIN=12000
PREVIEW_PORT_MAX=12999
# Stable ports for the two static lanes.
PREVIEW_STATIC_PORT_A=13001
PREVIEW_STATIC_PORT_B=13002
# Docker network previews join (must already exist).
# IMPORTANT: the cts recipe resolves containers BY NAME (frontend nginx proxies
# /v1,/v2 -> the backend container; the backend connects to the cts-preview-pg
# container). The default "bridge" network has NO automatic name resolution, so
# previews crash-loop ([emerg] host not found in upstream / DB unreachable). Use a
# USER-DEFINED network that also hosts cts-preview-pg and the static backends.
PREVIEW_DOCKER_NETWORK=cts-static

# --- Optional nginx vhosts (friendly URLs) ---
PREVIEW_NGINX_ENABLED=0
PREVIEW_DOMAIN=preview.cts.local
PREVIEW_NGINX_VHOST_DIR=/etc/nginx/sites-enabled

# --- Lifecycle ---
PREVIEW_MAX_CONCURRENT=2
# State dir holding per-preview compose + metadata (used by list/reap).
MAGESTIC_PREVIEW_STATE=/home/saya/.magestic-preview
